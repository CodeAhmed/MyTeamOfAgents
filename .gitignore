gitignore_content = r'''# ============================================================
# MyTeamOfAgents — .gitignore
# ============================================================

# ---- Environment & Secrets ----
.env
.env.local
.env.*.local
*.pem
*.key
*.secret

# ---- OpenClaw Internal State ----
.openclaw/

# ---- Docker ----
infra/postgres/data/
infra/redis/data/

# ---- Python ----
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python
env/
venv/
.venv/
*.egg-info/
dist/
build/
.pytest_cache/
.mypy_cache/

# ---- Node / React (Kanban Dashboard) ----
node_modules/
services/kanban_dashboard/node_modules/
services/kanban_dashboard/.next/
services/kanban_dashboard/dist/
services/kanban_dashboard/build/
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# ---- .NET / C# (Skills) ----
bin/
obj/
*.user
*.suo
*.vs/
.vs/
*.nupkg
*.snupkg
TestResults/

# ---- macOS ----
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# ---- IDE ----
.vscode/
.idea/
*.swp
*.swo
*.sublime-project
*.sublime-workspace

# ---- Logs ----
*.log
logs/

# ---- Brain / Memory (keep structure, ignore large data files) ----
brain/memory/reflections/*.json
brain/memory/patterns/*.json
brain/memory/preferences/*.json

# ---- Avatars (keep folder, ignore large binaries if needed) ----
# Uncomment below if you do NOT want to commit avatar images:
# brain/avatars/
'''

with open('.gitignore', 'w', encoding='utf-8') as f:
    f.write(gitignore_content)

print('.gitignore created')